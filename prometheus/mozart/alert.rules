groups:
  - name: container-monitoring
    rules:
      - alert: container_disappeared
        expr: time() - container_last_seen{container_label_monitor_group="monitoring"} > 300
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Container disappeared: {{ $labels.name }} on {{ $labels.hostname }}"
          description: "The container '{{ $labels.name }}' on '{{ $labels.hostname }}' has not been seen in cadvisor metrics for over 5 minutes."

      - alert: scrape_target_down
        expr: up == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Scrape failure for {{ $labels.job }} on {{ $labels.hostname }}"
          description: "Prometheus failed to scrape the job '{{ $labels.job }}' (instance {{ $labels.instance }}) on '{{ $labels.hostname }}' for at least 2 minutes."

  # NightHawk22 direct-extraction pipeline (Spotify + YouTube Studio).
  # Metrics arrive via the node_exporter textfile collector as nh22_source_*.
  # Routing: kind=auth -> email (needs a human at a keyboard); kind=data|error -> Slack.
  - name: nh22-extractor
    rules:
      # Re-auth broken. auth_required stays 1 between runs, so 65m ~= 2 consecutive
      # hourly runs still failing -> page rather than let data quietly go stale.
      - alert: NH22ExtractorAuthRequired
        expr: nh22_source_auth_required == 1
        for: 65m
        labels:
          severity: critical
          service: nh22-extractor
          kind: auth
        annotations:
          summary: "nh22 {{ $labels.source }} needs re-auth"
          description: "Source '{{ $labels.source }}' has reported AUTH_REQUIRED for 2+ consecutive runs. Scheduled extraction is blocked until you re-authenticate."
          runbook: "spotify: usually self-heals (scripted TOTP); if a captcha appeared run `docker compose run --rm -p 6080:6080 extractor node src/reauth.mjs spotify`. yts: open the noVNC URL and sign in via `docker compose run --rm -p 6080:6080 extractor node src/reauth.mjs yts`. See nighthawk22-analytics/extractor/RUNBOOK.md."

      # Data-missing signal: alert only once we're missing MORE THAN 2 DAYS' worth
      # of data. last_success_timestamp advances daily in normal operation (age
      # stays under ~25h), so >48h means a full day was missed. Independent of the
      # run's self-reported status, so it catches silent breakage too. Guarded on
      # >0 so a brand-new deploy (never-succeeded) doesn't fire before first success.
      - alert: NH22DataStale
        expr: nh22_source_last_success_timestamp > 0 and (time() - nh22_source_last_success_timestamp) > 172800 and (time() - nh22_source_last_success_timestamp) <= 259200
        for: 15m
        labels:
          severity: warning
          service: nh22-extractor
          kind: data
        annotations:
          summary: "nh22 {{ $labels.source }} missing >2 days of data"
          description: "No confirmed-complete gate for '{{ $labels.source }}' in over 2 days."

      # Escalation: still missing after 3 days -> the pipeline is almost certainly broken.
      - alert: NH22DataStaleCritical
        expr: nh22_source_last_success_timestamp > 0 and (time() - nh22_source_last_success_timestamp) > 259200
        for: 15m
        labels:
          severity: critical
          service: nh22-extractor
          kind: data
        annotations:
          summary: "nh22 {{ $labels.source }} missing >3 days of data"
          description: "No confirmed-complete gate for '{{ $labels.source }}' in over 3 days. The pipeline is likely broken."

      # Unexpected/unclassified failure across 2+ consecutive hourly runs.
      - alert: NH22ExtractorRunError
        expr: nh22_source_last_run_status{status="UNKNOWN"} == 1
        for: 65m
        labels:
          severity: warning
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 {{ $labels.source }} run error (UNKNOWN)"
          description: "'{{ $labels.source }}' classified UNKNOWN for 2+ consecutive runs — check extractor container logs."

      # Metrics stopped being written at all (textfile absent) — belt for the whole job.
      - alert: NH22ExtractorMetricsMissing
        expr: absent(nh22_source_last_run_timestamp)
        for: 3h
        labels:
          severity: warning
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 extractor metrics missing"
          description: "No nh22_source_* metrics for 3h — the extractor may not be running or the textfile mount is broken."