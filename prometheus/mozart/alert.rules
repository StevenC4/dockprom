groups:
  - name: container-monitoring
    rules:
      - alert: container_disappeared
        expr: time() - container_last_seen{container_label_monitor_group="monitoring"} > 300
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Container disappeared: {{ $labels.name }} on {{ $labels.hostname }}"
          description: "The container '{{ $labels.name }}' on '{{ $labels.hostname }}' has not been seen in cadvisor metrics for over 5 minutes."

      - alert: scrape_target_down
        expr: up == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Scrape failure for {{ $labels.job }} on {{ $labels.hostname }}"
          description: "Prometheus failed to scrape the job '{{ $labels.job }}' (instance {{ $labels.instance }}) on '{{ $labels.hostname }}' for at least 2 minutes."

  # The alerting pipeline itself — "who watches the watcher".
  # Everything here routes to EMAIL (service="alerting" in alertmanager's config),
  # deliberately NOT Slack: these fire exactly when Slack delivery is broken, so a
  # Slack-routed self-alert would be a closed loop that can never report.
  - name: alerting-pipeline
    rules:
      # THE rule that would have caught the July 2026 outage on day one. Every
      # nh22 alert fired correctly for 9 days and every one died at the last hop
      # ("open /etc/alertmanager/slack_webhook_url: permission denied"), visible
      # only in alertmanager's own container log, which nothing read.
      - alert: AlertmanagerNotificationsFailing
        expr: rate(alertmanager_notifications_failed_total[10m]) > 0
        for: 15m
        labels:
          severity: critical
          service: alerting
        annotations:
          summary: "Alertmanager cannot deliver to {{ $labels.integration }}"
          description: "The '{{ $labels.integration }}' receiver has been failing to deliver for 15m+. Alerts are being generated and silently dropped. Check `docker logs alertmanager`."
          runbook: "Most likely causes: unreadable api_url_file (must be readable by uid 65534 `nobody`), an expired/revoked Slack webhook, or no egress. Verify with: docker exec alertmanager head -c 30 /etc/alertmanager/slack_webhook_url"

      # Prometheus lost its link to alertmanager entirely — nothing can be delivered.
      - alert: AlertmanagerUnreachable
        expr: up{job="alertmanager"} == 0
        for: 10m
        labels:
          severity: critical
          service: alerting
        annotations:
          summary: "Alertmanager is unreachable from Prometheus"
          description: "Prometheus has failed to scrape alertmanager for 10m+. Alert delivery is likely down entirely."

  # NightHawk22 direct-extraction pipeline (Spotify + YouTube Studio).
  # Metrics arrive via the node_exporter textfile collector as nh22_source_*.
  # Routing: kind=auth -> email (needs a human at a keyboard); kind=data|error -> Slack.
  - name: nh22-extractor
    rules:
      # Re-auth broken. auth_required stays 1 between runs, so 65m ~= 2 consecutive
      # hourly runs still failing -> page rather than let data quietly go stale.
      - alert: NH22ExtractorAuthRequired
        expr: nh22_source_auth_required == 1
        for: 65m
        labels:
          severity: critical
          service: nh22-extractor
          kind: auth
        annotations:
          summary: "nh22 {{ $labels.source }} needs re-auth"
          description: "Source '{{ $labels.source }}' has reported AUTH_REQUIRED for 2+ consecutive runs. Scheduled extraction is blocked until you re-authenticate."
          runbook: "spotify: usually self-heals (scripted TOTP); if a captcha appeared run `docker compose run --rm -p 6080:6080 extractor node src/reauth.mjs spotify`. yts: open the noVNC URL and sign in via `docker compose run --rm -p 6080:6080 extractor node src/reauth.mjs yts`. See nighthawk22-analytics/extractor/RUNBOOK.md."

      # Data-missing signal: alert only once we're missing MORE THAN 2 DAYS' worth
      # of data. last_success_timestamp advances daily in normal operation (age
      # stays under ~25h), so >48h means a full day was missed. Independent of the
      # run's self-reported status, so it catches silent breakage too. Guarded on
      # >0 so a brand-new deploy (never-succeeded) doesn't fire before first success.
      - alert: NH22DataStale
        expr: nh22_source_last_success_timestamp > 0 and (time() - nh22_source_last_success_timestamp) > 172800 and (time() - nh22_source_last_success_timestamp) <= 259200
        for: 15m
        labels:
          severity: warning
          service: nh22-extractor
          kind: data
        annotations:
          summary: "nh22 {{ $labels.source }} missing >2 days of data"
          description: "No confirmed-complete gate for '{{ $labels.source }}' in over 2 days."

      # Escalation: still missing after 3 days -> the pipeline is almost certainly broken.
      - alert: NH22DataStaleCritical
        expr: nh22_source_last_success_timestamp > 0 and (time() - nh22_source_last_success_timestamp) > 259200
        for: 15m
        labels:
          severity: critical
          service: nh22-extractor
          kind: data
        annotations:
          summary: "nh22 {{ $labels.source }} missing >3 days of data"
          description: "No confirmed-complete gate for '{{ $labels.source }}' in over 3 days. The pipeline is likely broken."

      # The extraction path is DEAD BEHIND A PASSING GATE — the third variant of
      # "the metric does not mean what you think" in this group (see absent() vs
      # stale below).
      #
      # NH22DataStale above watches last_success_timestamp, which advances whenever
      # the completeness GATE is satisfied — including on short-circuit runs that
      # never open a browser. So a source whose gate target is already in Postgres
      # reports perfectly healthy while its browser is broken. On 2026-07-23 a
      # stale Xvfb lock file broke every Chromium launch; spotify was caught
      # (its gate target was missing, so last_success froze) but yts sailed on,
      # because its lagged gate stayed satisfied from an earlier run's window.
      # Detection for yts would have taken ~4-5 days via DataStale.
      #
      # last_extraction_timestamp only advances when a browser run actually
      # completed, so it catches this directly. Thresholds differ per source
      # because cadence does: the gate targets today-(1+lag) while each run pulls
      # the whole 35-day window, so a source only re-extracts every lag+1 days.
      #   spotify: lag 0 -> extracts daily          -> 48h
      #   yts:     lag 1 -> extracts every 2nd day  -> 72h
      # The bare (unlabelled) arm is the 72h catch-all so a NEWLY ADDED source is
      # covered by default rather than silently unmonitored; spotify is then
      # tightened on top of it. If NH22_YTS_LAG_DAYS changes, re-derive 72h as
      # (lag+1) days + ~1 day of slack.
      #
      # Guarded on >0: the gauge is 0 until a source's first real extraction under
      # this state key, and an unguarded time()-0 fires instantly on deploy.
      - alert: NH22ExtractorNotExtracting
        expr: >-
          (nh22_source_last_extraction_timestamp > 0 and (time() - nh22_source_last_extraction_timestamp) > 259200)
          or
          (nh22_source_last_extraction_timestamp{source="spotify"} > 0 and (time() - nh22_source_last_extraction_timestamp{source="spotify"}) > 172800)
        for: 30m
        labels:
          severity: warning
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 {{ $labels.source }} has not actually extracted"
          description: "'{{ $labels.source }}' has not completed a real extraction in longer than its expected cadence, even though its completeness gate may still look satisfied. The browser/session path is probably broken."
          runbook: "Check `docker compose logs extractor` for 'FATAL: Xvfb failed to start' or a Chromium launch failure, then the auth sections. See nighthawk22-analytics/extractor/RUNBOOK.md#no-xserver."

      # Unexpected/unclassified failure across 2+ consecutive hourly runs.
      - alert: NH22ExtractorRunError
        expr: nh22_source_last_run_status{status="UNKNOWN"} == 1
        for: 65m
        labels:
          severity: warning
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 {{ $labels.source }} run error (UNKNOWN)"
          description: "'{{ $labels.source }}' classified UNKNOWN for 2+ consecutive runs — check extractor container logs."

      # Metrics stopped being written at all (textfile absent) — belt for the whole job.
      - alert: NH22ExtractorMetricsMissing
        expr: absent(nh22_source_last_run_timestamp)
        for: 3h
        labels:
          severity: warning
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 extractor metrics missing"
          description: "No nh22_source_* metrics for 3h — the extractor may not be running or the textfile mount is broken."

      # The job is not EXECUTING at all — distinct from executing and failing.
      #
      # NH22ExtractorMetricsMissing above cannot catch this, and did not: it uses
      # absent(), but the .prom file is a FILE. When the extractor stops running,
      # node_exporter happily keeps serving the last one it wrote, forever. The
      # series never goes absent, it goes STALE — so staleness is what to alert on.
      # In July 2026 the extractor container was deleted (a `docker system prune`
      # removes exited one-shots) and ofelia failed with "No such container" on
      # every tick for 9 days while this metric sat frozen and absent() stayed false.
      #
      # Normal cadence is 8 runs/day in the 07:00-14:00 MT window, so last_run
      # should never be older than ~24h. 30h clears a full window plus slack.
      - alert: NH22ExtractorNotRunning
        expr: nh22_source_last_run_timestamp > 0 and (time() - nh22_source_last_run_timestamp) > 108000
        for: 30m
        labels:
          severity: critical
          service: nh22-extractor
          kind: error
        annotations:
          summary: "nh22 {{ $labels.source }} extractor has not run in 30h"
          description: "The extractor has not EXECUTED for '{{ $labels.source }}' in over 30h — its metrics file is frozen, not missing. The scheduled job is not firing at all."
          runbook: "Check `docker compose logs ofelia | tail`. 'No such container' means the one-shot containers were removed (e.g. by docker system prune); recreate them with `make up` in nighthawk22-analytics."